# Application Environment (development, test, production)
# In production, Gin runs in release mode and SQL logs are silenced.
APP_ENV=development

# The port the backend server will bind to. (Render will provide this automatically in production)
PORT=8080

# Database (Supabase PostgreSQL)
# For Render, use the connection pooler URL (e.g. Transaction mode, port 6543)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Secret - MUST be changed to a strong random string in production!
JWT_SECRET=your-jwt-secret-change-in-production

# CORS
# Comma-separated list of allowed origins. e.g. https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Admin Seed (Used during first startup to create the default admin)
# In production, use a strong password!
ADMIN_SEED_EMAIL=admin@marketops.local
ADMIN_SEED_PASSWORD=Admin123!
ADMIN_SEED_NAME=Admin

# Supabase Storage (for future product images)
SUPABASE_STORAGE_URL=https://[YOUR-PROJECT-REF].supabase.co/storage/v1
SUPABASE_STORAGE_BUCKET=product-images
# IMPORTANT: Service role key MUST NEVER be exposed to the frontend!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

